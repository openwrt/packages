# UPnP IGD & PCP/NAT-PMP Service Settings (v1.1)
config upnpd 'config'
	option enabled                    '0'
	option enable_upnp_igd            '1'
	option enable_pcp_natpmp          '1'
	option use_stun                   '0'
	option allow_third_party_mapping  '0'
	option ipv6_disable               '0'
	option upnp_igd_compat            'igdv1'
	# By default, looked up dynamically from ubus
	#option external_iface            'wan'
	# Multiple LAN interfaces can be specified, separated by a space
	#option internal_iface            'lan'

# Access Control List (ACL)
# An empty ACL is denied. IPv6 is currently always allowed unless disabled.
config perm_rule
	option comment                    'HTTP port (template)'
	option action                     'deny'
	option int_addr                   '0.0.0.0/0'
	option int_ports                  '80'
	option ext_ports                  '80'

config perm_rule
	option comment                    'HTTPS port (template)'
	option action                     'deny'
	option int_addr                   '0.0.0.0/0'
	option int_ports                  '443'
	option ext_ports                  '443'

config perm_rule
	option comment                    'Low/system ports (template)'
	option action                     'deny'
	option int_addr                   '0.0.0.0/0'
	option int_ports                  '1-1023'
	option ext_ports                  '1-1023'

config perm_rule
	option comment                    'High ports (allowed by default)'
	option action                     'allow'
	option int_addr                   '0.0.0.0/0'
	option int_ports                  '1024-65535'
	option ext_ports                  '1024-65535'
