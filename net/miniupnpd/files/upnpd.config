# UPnP IGD & PCP/NAT-PMP Service Settings (v2.0)

config upnpd 'config'
	option enabled                    '0'
	# Can be set to all/upnp-igd/pcp+nat-pmp
	option enabled_protocols          'all'
	option allow_third_party_mapping  '0'
	# Extra logging by setting to info or debug (previously 1)
	option log_output                 'default'
	option upnp_igd_compat            'igdv1'
	# Report interface link speed by default, options now in kbit/s
	#option upnp_igd_download
	#option upnp_igd_upload
	#option upnp_igd_friendly_name    'OpenWrt router'

# Enabled Networks / Access Control
# To check custom ACL unset acl_preset or set acl_custom_first to 1

config internal_network
	option interface                  'lan'
	option acl_preset                 'accept-high-ports'

# Custom ACL
# An empty ACL is rejected, and IPv6 is always accepted unless disabled
# Action can now be set to accept/reject/disabled

config perm_rule
	option comment                    'High ports'
	option action                     'disabled'
	option int_addr                   '0.0.0.0/0'
	option int_ports                  '1024-65535'
	option ext_ports                  '1024-65535'

config perm_rule
	option comment                    'HTTPS port'
	option action                     'disabled'
	option int_addr                   '0.0.0.0/0'
	option int_ports                  '443'
	option ext_ports                  '443'

config perm_rule
	option comment                    'Low/system ports'
	option action                     'disabled'
	option int_addr                   '0.0.0.0/0'
	option int_ports                  '1-1023'
	option ext_ports                  '1-1023'

config perm_rule
	option comment                    'All ports'
	option action                     'disabled'
	option int_addr                   '0.0.0.0/0'
	option int_ports                  '1-65535'
	option ext_ports                  '1-65535'
