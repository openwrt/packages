+/* greedy parser: try to match the longest sequence and do not
+ * check for terminators */
+
+static const char *
+get_sep(const char * s)
+{
+	if(!isspace(*s))
+		return NULL;
+	do
+		s++;
+	while(isspace(*s));
+	return (char *) s;
+}
+
+static const char *
+get_ushort(const char * s, u_short * val)
+{
+	char * end;
+	unsigned long val_ul;
+
+	if(!isdigit(*s))
+		return NULL;
+	val_ul = strtoul(s, &end, 10);
+	if(val_ul > 65535)
+		return NULL;
+	*val = (u_short)val_ul;
+
+	return end;
+}
+
+static const char *
+get_range(const char * s, u_short * begin, u_short * end)
+{
+	s = get_ushort(s, begin);
+	if(!s)
+		return NULL;
+
+	if(*s!='-')
+		*end = *begin;
+	else
+	{
+		s++;
+		s = get_ushort(s, end);
+		if(!s)
+			return NULL;
+		if(*begin > *end)
+			return NULL;
+	}
+	return s;
+}
+
+static const char *
+get_addr(const char * s, struct in_addr * addr, unsigned int * dot_cnt)
+{
+	size_t i;
+	char buf[64];
+
+	if(!isdigit(*s))
+		return NULL;
+
+	*dot_cnt = 0;
+	for(i = 0; isdigit(s[i]) || s[i] == '.';)
+	{
+		if(s[i] == '.')
+			(*dot_cnt)++;
+		buf[i] = s[i];
+		i++;
+		if (i > sizeof(buf) - 1)
+			return NULL;
+	}
+
+	buf[i] = '\0';
+	if(!inet_aton(buf, addr))
+		return NULL;
+
+	return s + i;
+}
