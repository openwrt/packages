	local config="$2"

	uci_validate_section xfrpc socks5 $section \
		'enabled:bool:1' \
		'remote_port:uinteger' \
		'start_time:string' \
		'end_time:string'

	[ $enabled = 0 ] && return

	echo "[[proxies]]" >> "$config"
	echo "name = \"$section\"" >> "$config"
	echo "type = \"socks5\"" >> "$config"
	toml_kv_int "remotePort" "$remote_port" "$config"
	toml_kv_int "startTime" "$start_time" "$config"
	toml_kv_int "endTime" "$end_time" "$config"
}

handle_tcpmux() {
	local section="$1"
	local config="$2"

	uci_validate_section xfrpc tcpmux $section \
		'enabled:bool:1' \
		'local_ip:host' \
		'local_port:uinteger' \
		'remote_port:uinteger' \
		'custom_domains:string' \
		'multiplexer:string' \
		'service_type:string' \
		'use_encryption:bool:0' \
		'use_compression:bool:0' \
		'start_time:string' \
		'end_time:string'

	[ $enabled = 0 ] && return

	# Validate service_type if provided
	if [ -n "$service_type" ]; then
		case "$service_type" in
			ssh|mstsc|rdp|vnc|telnet|http|https) ;;
			*)
				echo "Error: Invalid service_type '$service_type'. Must be one of: ssh, mstsc, rdp, vnc, telnet, http, https"
				return 1
				;;
		esac
	fi

	# Validate multiplexer type if provided
	if [ -n "$multiplexer" ]; then
		case "$multiplexer" in
			httpconnect|socks5|raw|quic) ;;
			*)
				echo "Error: Invalid multiplexer '$multiplexer'. Must be one of: httpconnect, socks5, raw, quic"
				return 1
				;;
		esac
	fi

	echo "[[proxies]]" >> "$config"
	echo "name = \"$section\"" >> "$config"
	echo "type = \"tcpmux\"" >> "$config"
	toml_kv "localIP" "$local_ip" "$config"
	toml_kv_int "localPort" "$local_port" "$config"
	toml_kv_int "remotePort" "$remote_port" "$config"
	toml_kv "serviceType" "$service_type" "$config"
	toml_kv "multiplexer" "$multiplexer" "$config"
	[ "$use_encryption" = "1" ] && echo "transport.useEncryption = true" >> "$config"
	[ "$use_compression" = "1" ] && echo "transport.useCompression = true" >> "$config"
	if [ -n "$custom_domains" ]; then
		local arr=""
		for d in $custom_domains; do
			[ -n "$arr" ] && arr="$arr, "
			arr="$arr\"$d\""
		done
		echo "customDomains = [$arr]" >> "$config"
	fi
	# Time-based proxy management (xfrpc unique)
	toml_kv_int "startTime" "$start_time" "$config"
	toml_kv_int "endTime" "$end_time" "$config"
}

