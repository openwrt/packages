handle_plugin() {
	local section="$1"
	local config="$2"

	uci_validate_section xfrpc plugin $section \
		'enabled:bool:1' \
		'remote_port:uinteger' \
		'plugin_name:string' \
		'plugin_user:string' \
		'plugin_pwd:string' \
		'plugin_unix_path:string'

	[ $enabled = 0 ] && return

	echo "[${section}]" >> "$config"
	echo "type = plugin" >> "$config"
	[ -z "$remote_port" ] || echo "remote_port = $remote_port" >> "$config"
	[ -z "$plugin_name" ] || echo "plugin_name = $plugin_name" >> "$config"
	[ -z "$plugin_user" ] || echo "plugin_user = $plugin_user" >> "$config"
	[ -z "$plugin_pwd" ] || echo "plugin_pwd = $plugin_pwd" >> "$config"
	[ -z "$plugin_unix_path" ] || echo "plugin_unix_path = $plugin_unix_path" >> "$config"
}

service_triggers() {
	procd_add_reload_trigger "$NAME"
	procd_add_interface_trigger "interface.*.up" wan /etc/init.d/xfrpc restart
}

start_service() {
	local conf_file="/var/etc/$NAME.ini"

	> "$conf_file"
	config_load "$NAME"

	local enabled=$(uci get xfrpc.common.enabled 2>/dev/null)
	local loglevel=$(uci get xfrpc.common.loglevel 2>/dev/null)

	if [ "$enabled" = "0" ] || [ "$enabled" = "false" ]; then
		echo "xfrpc service disabled"
		return
	fi

	config_foreach handle_xfrpc xfrpc "$conf_file"
	config_foreach handle_tcp tcp "$conf_file"
	config_foreach handle_http http "$conf_file"
	config_foreach handle_https https "$conf_file"
	config_foreach handle_socks5 socks5 "$conf_file"
	config_foreach handle_iod iod "$conf_file"
	config_foreach handle_tcpmux tcpmux "$conf_file"
	config_foreach handle_stcp stcp "$conf_file"
	config_foreach handle_xtcp xtcp "$conf_file"
	config_foreach handle_sudp sudp "$conf_file"
	config_foreach handle_stcp_visitor stcp_visitor "$conf_file"
	config_foreach handle_xtcp_visitor xtcp_visitor "$conf_file"
	config_foreach handle_plugin plugin "$conf_file"

	procd_open_instance
	procd_set_param command "$PROG" -c "$conf_file" -s -f -d $loglevel
	procd_set_param file "$conf_file"
	procd_set_param respawn
	procd_close_instance
}

reload_service() {
	stop
	start
}
