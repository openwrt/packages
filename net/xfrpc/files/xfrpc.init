START=99
USE_PROCD=1

NAME=xfrpc
PROG=/usr/bin/$NAME


handle_xfrpc() {
    local section="$1"
    local config="$2"

    # Read settings directly from UCI (uci_validate_section has issues with
    # some option names containing underscores like tls_key_file)
    local server_addr=$(uci get xfrpc.${section}.server_addr 2>/dev/null)
    local server_port=$(uci get xfrpc.${section}.server_port 2>/dev/null)
    local token=$(uci get xfrpc.${section}.token 2>/dev/null)
    local tcp_mux=$(uci get xfrpc.${section}.tcp_mux 2>/dev/null)
    local protocol=$(uci get xfrpc.${section}.protocol 2>/dev/null)
    local quic_bind_port=$(uci get xfrpc.${section}.quic_bind_port 2>/dev/null)
    local heartbeat_interval=$(uci get xfrpc.${section}.heartbeat_interval 2>/dev/null)
    local heartbeat_timeout=$(uci get xfrpc.${section}.heartbeat_timeout 2>/dev/null)
    local tls_enable=$(uci get xfrpc.${section}.tls_enable 2>/dev/null)
    local tls_cert_file=$(uci get xfrpc.${section}.tls_cert_file 2>/dev/null)
    local tls_key_file=$(uci get xfrpc.${section}.tls_key_file 2>/dev/null)
    local tls_trusted_ca_file=$(uci get xfrpc.${section}.tls_trusted_ca_file 2>/dev/null)
    local tls_server_name=$(uci get xfrpc.${section}.tls_server_name 2>/dev/null)

    # Warn if TLS enabled but client cert/key missing
    if [ -n "$tls_enable" ] && [ "$tls_enable" != "0" ]; then
        if [ -z "$tls_cert_file" ] || [ -z "$tls_key_file" ]; then
            logger -t xfrpc "WARN: tls_enable=1 but tls_cert_file/tls_key_file not set"
        elif [ ! -f "$tls_cert_file" ] || [ ! -f "$tls_key_file" ]; then
            logger -t xfrpc "WARN: TLS cert/key file not found: $tls_cert_file / $tls_key_file"
        fi
    fi

    # Write the validated settings to the config file
    echo "[${section}]" >> "$config"
    [ -z "$server_addr" ] || echo "server_addr = $server_addr" >> "$config"
    [ -z "$server_port" ] || echo "server_port = $server_port" >> "$config"
    [ -z "$token" ] || echo "token = $token" >> "$config"
    [ -n "$tcp_mux" ] && [ "$tcp_mux" != "0" ] && echo "tcp_mux = $tcp_mux" >> "$config"
    [ -z "$protocol" ] || echo "protocol = $protocol" >> "$config"
    [ -n "$quic_bind_port" ] && [ "$quic_bind_port" != "0" ] && echo "quic_bind_port = $quic_bind_port" >> "$config"
    [ -n "$heartbeat_interval" ] && [ "$heartbeat_interval" != "30" ] && echo "heartbeat_interval = $heartbeat_interval" >> "$config"
    [ -n "$heartbeat_timeout" ] && [ "$heartbeat_timeout" != "90" ] && echo "heartbeat_timeout = $heartbeat_timeout" >> "$config"
    [ -n "$tls_enable" ] && [ "$tls_enable" != "0" ] && echo "tls_enable = $tls_enable" >> "$config"
    [ -z "$tls_cert_file" ] || echo "tls_cert_file = $tls_cert_file" >> "$config"
    [ -z "$tls_key_file" ] || echo "tls_key_file = $tls_key_file" >> "$config"
    [ -z "$tls_trusted_ca_file" ] || echo "tls_trusted_ca_file = $tls_trusted_ca_file" >> "$config"
    [ -z "$tls_server_name" ] || echo "tls_server_name = $tls_server_name" >> "$config"
}

handle_tcp() {
	local section="$1"
	local config="$2"

	uci_validate_section xfrpc tcp $section \
		'enabled:bool:1' \
		'service_type:string' \
		'local_ip:host' \
		'local_port:uinteger' \
		'remote_port:uinteger' \
		'health_check_type:string' \
		'health_check_url:string' \
		'health_check_interval:uinteger' \
		'health_check_timeout:uinteger' \
		'health_check_max_failed:uinteger' \
		'start_time:string' \
		'end_time:string'
	
	# if enabled is 0, then return
	[ $enabled = 0 ] && return

	# Validate service_type if provided
	if [ -n "$service_type" ]; then
		case "$service_type" in
			ssh|mstsc|rdp|vnc|telnet)
				# Valid service type
				;;
			*)
				echo "Error: Invalid service_type '$service_type'. Must be one of: ssh, mstsc, rdp, vnc, telnet"
				return 1
				;;
		esac
	fi

	# Write the validated settings to the config file
	echo "[${section}]" >> "$config"
	echo "type = tcp" >> "$config"
	[ -z "$service_type" ] || echo "service_type = $service_type" >> "$config"
	[ -z "$local_ip" ] || echo "local_ip = $local_ip" >> "$config"
	[ -z "$local_port" ] || echo "local_port = $local_port" >> "$config"
	[ -z "$remote_port" ] || echo "remote_port = $remote_port" >> "$config"
	[ -z "$health_check_type" ] || echo "health_check_type = $health_check_type" >> "$config"
	[ -z "$health_check_url" ] || echo "health_check_url = $health_check_url" >> "$config"
	[ -z "$health_check_interval" ] || echo "health_check_interval = $health_check_interval" >> "$config"
	[ -z "$health_check_timeout" ] || echo "health_check_timeout = $health_check_timeout" >> "$config"
	[ -z "$health_check_max_failed" ] || echo "health_check_max_failed = $health_check_max_failed" >> "$config"
	[ -z "$start_time" ] || echo "start_time = $start_time" >> "$config"
	[ -z "$end_time" ] || echo "end_time = $end_time" >> "$config"
}

