config nss-switch 'settings'
    option persist_default 'no'
    option nss_mark '0x00010000'
    option nss_mark_mask '0x00010000'
    option ecm_debugfs '/sys/kernel/debug/ecm'
    option nft_table 'inet fw4'
    option nft_chain_pre 'nss_bypass_pre'
    option nft_chain_post 'nss_bypass_post'
    option rules_file '/etc/nss-switch/rules.conf'
    option debug_log '/tmp/nss-switch.log'
    option fw_script '/etc/firewall.d/nss-bypass-rules'
    option watch_interval '3'
    option debug_mode 'no'
