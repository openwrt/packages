+{
+	if (!conn)
+		return GETDNS_RETURN_INVALID_PARAMETER;
+	conn->min_tls = min;
+	conn->max_tls = max;
+	apply_connection_tls_version(conn);
+	return GETDNS_RETURN_GOOD;
+}
