+	case LDNS_SHA1:
+		return _digest_mbedtls(SHA1_DIGEST_SIZE, buf, len, res);
+#endif
+#if defined(USE_SHA2)
+	case LDNS_SHA256:
+		return _digest_mbedtls(SHA256_DIGEST_SIZE, buf, len, res);
+#endif
+#ifdef USE_ECDSA
+	case LDNS_SHA384:
+		return _digest_mbedtls(SHA384_DIGEST_SIZE, buf, len, res);
