choice
        prompt "Select Database Software"
        default ZABBIX_POSTGRESQL

        config ZABBIX_MYSQL
                bool "MySQL/MariaDB"

        config ZABBIX_POSTGRESQL
                bool "PostgreSQL"
endchoice

choice
        prompt "Select SSL Library"
        default ZABBIX_GNUTLS

        config ZABBIX_GNUTLS
                bool "GnuTLS"

        config ZABBIX_OPENSSL
                bool "OpenSSL"
endchoice
