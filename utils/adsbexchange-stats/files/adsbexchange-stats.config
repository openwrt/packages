#
# /etc/config/adsbexchange-stats -- declarative only.
#
# Comments in this file DO NOT survive `uci commit`; every committer
# (uci, LuCI, our init script's reload trigger, readsb-uuid) rewrites
# the file in canonical form and strips every line starting with `#`.
# All option documentation therefore lives in:
#   /usr/share/doc/adsbexchange-stats/README.md  (or the source repo)
# and is also surfaced by:
#   service adsbexchange-stats info
#
# Station UUID and aircraft.json directory are inherited from
# /etc/config/readsb (readsb.main.uuid, readsb.main.write_json).
# Manage UUID with `readsb-uuid`. View logs with `logread -e adsbexchange-stats`.

config adsbexchange-stats main
	option enabled '1'
	option json_paths_override ''
	option log_level '1'
	option log_summary_interval '300'
	option dns_cache '0'
	option dns_ttl '600'
	option dns_ignore_local '0'
