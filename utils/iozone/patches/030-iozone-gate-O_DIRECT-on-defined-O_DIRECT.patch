Date: Sat, 13 Jun 2026 12:33:13 -0400
Subject: [PATCH 3/3] iozone: gate O_DIRECT on defined(O_DIRECT)

Auto-detect O_DIRECT instead of per-arch DONT_HAVE_O_DIRECT;
falls back cleanly where the flag is absent.
---
 src/current/iozone.c | 44 ++++++++++++++++++++++----------------------
 1 file changed, 22 insertions(+), 22 deletions(-)

--- a/src/current/iozone.c
+++ b/src/current/iozone.c
@@ -2052,7 +2052,7 @@ int * main(int argc,char **argv)
 			sprintf(splash[splash_line++],"\tVxFS advanced feature SET_CACHE, VX_DIRECT enabled\n");
 			break;
 #endif
-#if !defined(DONT_HAVE_O_DIRECT)
+#if !defined(DONT_HAVE_O_DIRECT) && defined(O_DIRECT)
   #if defined(linux) || defined(__AIX__) || defined(IRIX) || defined(IRIX64) || defined(Windows) || defined(__FreeBSD__) || defined(solaris) || defined(IOZ_macosx)
 			direct_flag++;
 #if defined __APPLE__ && __MACH__
@@ -7839,7 +7839,7 @@ long long *data2;
 		file_flags |=O_RSYNC|O_SYNC;
 #endif
 
-#if ! defined(DONT_HAVE_O_DIRECT)
+#if ! defined(DONT_HAVE_O_DIRECT) && defined(O_DIRECT)
 #if defined(linux) || defined(__AIX__) || defined(IRIX) || defined(IRIX64) || defined(Windows) || defined (__FreeBSD__)
 	if(direct_flag)
 		file_flags |=O_DIRECT;
@@ -8890,7 +8890,7 @@ long long *data1,*data2;
 	if(read_sync)
 		open_flags |=O_RSYNC|O_SYNC;
